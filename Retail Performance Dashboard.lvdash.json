{
  "datasets": [
    {
      "name": "product_performance",
      "displayName": "Product Performance",
      "config": {
        "version": "1.1",
        "source": "retail.gold.product_performance",
        "dimensions": [
          {
            "name": "product_id",
            "expr": "product_id"
          },
          {
            "name": "product_name",
            "expr": "product_name"
          },
          {
            "name": "category",
            "expr": "category"
          },
          {
            "name": "last_sold_date",
            "expr": "last_sold_date"
          }
        ],
        "measures": [
          {
            "name": "total_revenue",
            "expr": "ROUND(SUM(total_revenue), 2)"
          },
          {
            "name": "total_cost",
            "expr": "SUM(total_cost)"
          },
          {
            "name": "gross_profit",
            "expr": "ROUND(SUM(gross_profit), 2)"
          },
          {
            "name": "units_sold",
            "expr": "SUM(units_sold)"
          },
          {
            "name": "total_orders",
            "expr": "SUM(total_orders)"
          },
          {
            "name": "current_stock",
            "expr": "SUM(current_stock)"
          },
          {
            "name": "profit_margin",
            "expr": "SUM(gross_profit) / NULLIF(SUM(total_revenue), 0) * 100"
          }
        ]
      }
    },
    {
      "name": "customer_orders",
      "displayName": "Customer Orders",
      "config": {
        "version": "1.1",
        "source": "retail.gold.orders_summary",
        "dimensions": [
          {
            "name": "customer_id",
            "expr": "customer_id"
          },
          {
            "name": "name",
            "expr": "name"
          },
          {
            "name": "email",
            "expr": "email"
          },
          {
            "name": "customer_since",
            "expr": "customer_since"
          },
          {
            "name": "last_order_date",
            "expr": "last_order_date"
          }
        ],
        "measures": [
          {
            "name": "total_revenue",
            "expr": "SUM(total_revenue)"
          },
          {
            "name": "total_orders",
            "expr": "SUM(total_orders)"
          },
          {
            "name": "avg_order_value",
            "expr": "SUM(total_revenue) / NULLIF(SUM(total_orders), 0)"
          },
          {
            "name": "unique_products_purchased",
            "expr": "SUM(unique_products_purchased)"
          },
          {
            "name": "delivered_orders",
            "expr": "SUM(delivered_orders)"
          },
          {
            "name": "cancelled_orders",
            "expr": "SUM(cancelled_orders)"
          },
          {
            "name": "customer_count",
            "expr": "COUNT(DISTINCT customer_id)"
          }
        ]
      }
    },
    {
      "name": "daily_sales",
      "displayName": "Daily Sales",
      "config": {
        "version": "1.1",
        "source": "retail.gold.daily_sales",
        "dimensions": [
          {
            "name": "sales_date",
            "expr": "sales_date"
          }
        ],
        "measures": [
          {
            "name": "total_revenue",
            "expr": "SUM(total_revenue)"
          },
          {
            "name": "total_orders",
            "expr": "SUM(total_orders)"
          },
          {
            "name": "unique_customers",
            "expr": "SUM(unique_customers)"
          },
          {
            "name": "total_units_sold",
            "expr": "SUM(total_units_sold)"
          },
          {
            "name": "avg_order_value",
            "expr": "SUM(total_revenue) / NULLIF(SUM(total_orders), 0)"
          },
          {
            "name": "cancelled_orders",
            "expr": "SUM(cancelled_orders)"
          },
          {
            "name": "refunded_orders",
            "expr": "SUM(refunded_orders)"
          }
        ]
      }
    },
    {
      "name": "top_customers",
      "displayName": "Top 10 Customers",
      "config": {
        "version": "1.1",
        "source": "SELECT * FROM retail.gold.orders_summary ORDER BY total_revenue DESC LIMIT 10\n",
        "dimensions": [
          {
            "name": "customer_id",
            "expr": "customer_id"
          },
          {
            "name": "name",
            "expr": "name"
          },
          {
            "name": "email",
            "expr": "email"
          },
          {
            "name": "customer_since",
            "expr": "customer_since"
          },
          {
            "name": "last_order_date",
            "expr": "last_order_date"
          }
        ],
        "measures": [
          {
            "name": "total_revenue",
            "expr": "ROUND(SUM(total_revenue), 2)"
          },
          {
            "name": "total_orders",
            "expr": "SUM(total_orders)"
          },
          {
            "name": "avg_order_value",
            "expr": "SUM(total_revenue) / NULLIF(SUM(total_orders), 0)"
          }
        ]
      }
    },
    {
      "name": "top_products",
      "displayName": "Top 10 Products",
      "config": {
        "version": "1.1",
        "source": "SELECT * FROM retail.gold.product_performance ORDER BY total_revenue DESC LIMIT 10\n",
        "dimensions": [
          {
            "name": "product_id",
            "expr": "product_id"
          },
          {
            "name": "product_name",
            "expr": "product_name"
          },
          {
            "name": "category",
            "expr": "category"
          },
          {
            "name": "last_sold_date",
            "expr": "last_sold_date"
          }
        ],
        "measures": [
          {
            "name": "total_revenue",
            "expr": "SUM(total_revenue)",
            "format": {
              "hideGroupSeparator": false,
              "decimalPlaces": {
                "type": "all"
              },
              "currencyCode": "USD",
              "type": "currency",
              "abbreviation": "none"
            }
          },
          {
            "name": "total_cost",
            "expr": "SUM(total_cost)"
          },
          {
            "name": "gross_profit",
            "expr": "SUM(gross_profit)"
          },
          {
            "name": "units_sold",
            "expr": "SUM(units_sold)"
          },
          {
            "name": "total_orders",
            "expr": "SUM(total_orders)"
          },
          {
            "name": "profit_margin",
            "expr": "SUM(gross_profit) / NULLIF(SUM(total_revenue), 0) * 100",
            "format": {
              "type": "percentage",
              "decimalPlaces": {
                "type": "all"
              },
              "hideGroupSeparator": false
            }
          }
        ]
      }
    }
  ],
